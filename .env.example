# Core runtime
MTS_AGENT_PROVIDER=deterministic
MTS_EXECUTOR_MODE=local

# Local paths
MTS_DB_PATH=runs/mts.sqlite3
MTS_RUNS_ROOT=runs
MTS_KNOWLEDGE_ROOT=knowledge
MTS_SKILLS_ROOT=skills
MTS_CLAUDE_SKILLS_PATH=.claude/skills
MTS_EVENT_STREAM_PATH=runs/events.ndjson

# Model selection
MTS_MODEL_COMPETITOR=claude-sonnet-4-5-20250929
MTS_MODEL_ANALYST=claude-sonnet-4-5-20250929
MTS_MODEL_COACH=claude-opus-4-6
MTS_MODEL_ARCHITECT=claude-opus-4-6

# API credentials (set when using live providers)
MTS_ANTHROPIC_API_KEY=
MTS_PRIMEINTELLECT_API_BASE=https://api.primeintellect.ai
MTS_PRIMEINTELLECT_API_KEY=
MTS_PRIMEINTELLECT_DOCKER_IMAGE=python:3.11-slim
MTS_PRIMEINTELLECT_CPU_CORES=1.0
MTS_PRIMEINTELLECT_MEMORY_GB=2.0
MTS_PRIMEINTELLECT_DISK_SIZE_GB=5.0
MTS_PRIMEINTELLECT_TIMEOUT_MINUTES=30
MTS_PRIMEINTELLECT_WAIT_ATTEMPTS=60

# Execution / loop tuning
MTS_DEFAULT_GENERATIONS=1
MTS_SEED_BASE=1000
MTS_MATCHES_PER_GENERATION=3
MTS_ARCHITECT_EVERY_N_GENS=3
MTS_BACKPRESSURE_MIN_DELTA=0.005
MTS_MAX_RETRIES=2
MTS_RETRY_BACKOFF_SECONDS=0.25

# PrimeIntellect resilience
MTS_PRIMEINTELLECT_MAX_RETRIES=2
MTS_PRIMEINTELLECT_BACKOFF_SECONDS=0.75
MTS_ALLOW_PRIMEINTELLECT_FALLBACK=true

# Local sandbox behavior
MTS_LOCAL_SANDBOX_HARDENED=true
